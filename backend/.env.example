# Database
# For local dev, leave blank to use SQLite (society.db in backend folder).
# For production (Render/Railway), set to your Postgres connection string, e.g.:
# postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Auth
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email (Resend - https://resend.com, free tier: 100 emails/day, no card needed)
# 1. Sign up at resend.com
# 2. Verify a sending domain, OR use their sandbox "onboarding@resend.dev" sender for testing
# 3. Create an API key and paste below
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Overdue detection
# Number of days a complaint can stay open before it is flagged overdue
OVERDUE_THRESHOLD_DAYS=3

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# Frontend URL (used in email links + CORS)
FRONTEND_URL=http://localhost:5173
